1 REM ***********************************
2 REM * FUJINET GORILLAS - RELAY EDITION *
3 REM * NETWORK PLAY VIA CG GAME RELAY   *
4 REM * APPLE II HGR + FUJIAPPLE N-CMDS  *
5 REM * ORIGINAL ATARI PORT: ROB SHERMAN *
6 REM ***********************************
8 IF PEEK(104) <> 64 THEN POKE 103,1: POKE 104,64: POKE 16384,0: PRINT CHR$(4);"RUN GORILLAS": REM RELOCATE ABOVE HGR PAGE
10 REM LOGIC RUNS IN ATARI GR.7 SPACE (160X80), DISPLAY SCALED TO HGR
20 DIM H(15),C(15)
30 P1 = 0:P2 = 0:D$ = CHR$(4):E$ = CHR$(155):B$ = ""
35 BW = 0:CO = 0:ER = 0:NB = 0:ML = 0:T$ = "":RL$ = "":M$ = "":EF = 0
40 GOSUB 9000
42 GOSUB 8000: REM CONNECT VIA RELAY
50 GOTO 100
100 REM ====== NEW ROUND ======
110 IF IH = 1 THEN GOSUB 1000: GOSUB 8200
120 IF IH = 0 THEN GOSUB 8300
130 GOSUB 1500: REM BOTH: DRAW PLAYFIELD FROM ARRAYS
140 GOTO 300
300 REM ====== PLAYER 1 TURN ======
310 IF MT = 1 THEN PL = 1: GOSUB 6000: GOSUB 8400: GOTO 390
320 PL = 1: GOSUB 8500: REM RECEIVE OPPONENT SHOT
390 GOSUB 2000
400 IF HT = 1 THEN P1 = P1 + 1: GOTO 700
410 GOTO 500
500 REM ====== PLAYER 2 TURN ======
510 IF MT = 2 THEN PL = 2: GOSUB 6000: GOSUB 8400: GOTO 590
520 PL = 2: GOSUB 8500
590 GOSUB 2000
600 IF HT = 1 THEN P2 = P2 + 1: GOTO 700
610 GOTO 300
700 REM ====== ROUND OVER ======
710 POKE 34,0: TEXT : HOME
720 PRINT "ROUND OVER"
730 PRINT "PLAYER 1 (";N1$;") SCORE ";P1
740 PRINT "PLAYER 2 (";N2$;") SCORE ";P2
750 PRINT
760 IF MT = 1 THEN INPUT "PLAY AGAIN Y/N? ";A$: GOSUB 8600: GOTO 780
765 PRINT "WAITING FOR HOST...": GOSUB 8700
780 IF A$ = "Y" OR A$ = "y" THEN 100
800 PRINT D$;"NCLOSE 1": END
1000 REM ====== HOST: GENERATE CITY ======
1010 FOR I = 0 TO 15
1020 H(I) = 25 + INT(RND(1) * 35)
1030 C(I) = 1 + INT(RND(1) * 2)
1040 NEXT I
1080 GX = 15:GY = 79 - H(1) - 6
1085 HX = 135:HY = 79 - H(13) - 6
1090 RETURN
1200 REM ---- DRAW BUILDING I ----
1210 X1 = I * 10:YB = 79 - H(I)
1215 HC = 5:PP = 1: IF C(I) = 2 THEN HC = 6:PP = 0
1220 PA = INT(X1 * 1.75):PE = PA + 16:Y1 = YB * 2
1222 SX = PA: IF SX - INT(SX / 2) * 2 <> PP THEN SX = SX + 1
1225 HCOLOR= HC
1230 FOR PX = SX TO PE STEP 2: HPLOT PX,158 TO PX,Y1: NEXT PX
1240 HCOLOR= 7
1250 FOR WX = X1 + 2 TO X1 + 6 STEP 4
1260 FOR WY = YB + 4 TO 75 STEP 6
1270 PX = INT(WX * 1.75):PY = WY * 2
1275 HPLOT PX,PY TO PX + 2,PY: HPLOT PX,PY + 1 TO PX + 2,PY + 1
1280 NEXT WY: NEXT WX
1290 RETURN
1500 REM ====== DRAW PLAYFIELD FROM ARRAYS ======
1505 REM CALLED BY BOTH SIDES - NO RND IN HERE!
1510 HGR : POKE 34,20: HOME
1540 HCOLOR= 7: REM SUN
1545 HPLOT 133,20 TO 148,20: HPLOT 133,21 TO 148,21
1550 HPLOT 140,12 TO 140,28: HPLOT 141,12 TO 141,28
1554 LX = 75:LY = 5: GOSUB 3500:LX = 85: GOSUB 3500:LY = 15: GOSUB 3500:LX = 75: GOSUB 3500
1560 FOR I = 0 TO 15: GOSUB 1200: NEXT I
1580 LX = GX:LY = GY: GOSUB 3100
1585 LX = HX:LY = HY: GOSUB 3100
1590 VTAB 21: PRINT "P1 ";N1$;":";P1;"  P2 ";N2$;":";P2;
1600 RETURN
2000 REM ====== FIRE SHOT (DETERMINISTIC BOTH ENDS) ======
2005 GOSUB 1500: REM REDRAW STORED CITY FIRST
2020 HT = 0
2030 R = A * 3.14159 / 180
2040 IF PL = 1 THEN X = GX:Y = GY:VX = COS(R) * P / 12:VY = - SIN(R) * P / 12
2050 IF PL = 2 THEN X = HX:Y = HY:VX = - COS(R) * P / 12:VY = - SIN(R) * P / 12
2060 FOR T = 1 TO 140
2070 X = X + VX:Y = Y + VY:VY = VY + 0.18
2100 IX = INT(X):IY = INT(Y)
2110 IF IX < 1 OR IX > 158 OR IY > 78 THEN 2240
2115 IF IY < 1 THEN FOR D = 1 TO 10: NEXT D: GOTO 2230
2120 PX = INT(IX * 1.75):PY = IY * 2: HCOLOR= 7: HPLOT PX,PY TO PX + 1,PY
2140 IF PL = 1 AND ABS(IX - HX) < 5 AND ABS(IY - HY) < 6 THEN HT = 1: GOTO 2300
2150 IF PL = 2 AND ABS(IX - GX) < 5 AND ABS(IY - GY) < 6 THEN HT = 1: GOTO 2300
2160 BI = INT(IX / 10)
2170 IF BI < 0 OR BI > 15 THEN 2210
2180 BY = 79 - H(BI): IF IY >= BY THEN 2240
2210 FOR D = 1 TO 15: NEXT D
2220 HCOLOR= 4: HPLOT PX,PY TO PX + 1,PY
2230 NEXT T
2240 GOSUB 5000: FOR D = 1 TO 300: NEXT D
2270 RETURN
2300 REM ---- HIT! EXPLOSION ----
2301 GOSUB 5100
2302 EX = IX: IF EX < 4 THEN EX = 4
2303 IF EX > 155 THEN EX = 155
2304 EY = IY: IF EY < 4 THEN EY = 4
2305 IF EY > 75 THEN EY = 75
2306 HCOLOR= 7
2308 FOR E = 1 TO 4
2310 LX = EX - E:LY = EY: GOSUB 3500:LX = EX + E: GOSUB 3500
2311 LX = EX:LY = EY - E: GOSUB 3500:LY = EY + E: GOSUB 3500
2312 FOR D = 1 TO 40: NEXT D
2314 NEXT E
2316 FOR D = 1 TO 250: NEXT D
2330 RETURN
3100 REM ---- DRAW GORILLA AT LX,LY ----
3105 HCOLOR= 7: RESTORE :XG = LX:YG = LY
3110 FOR Q = 1 TO 12: READ DX,DY
3120 LX = XG + DX - 2:LY = YG + DY: GOSUB 3500
3130 NEXT Q: RETURN
3140 REM DX STORED +2: AC -BAS TOKENIZES A MINUS SIGN INSIDE DATA ($C9), WHICH READ REJECTS
3150 DATA 2,0,1,1,3,1,0,2,1,2,2,2,3,2,4,2,1,3,3,3,0,4,4,4
3500 REM ---- PLOT LOGICAL PIXEL LX,LY AS 2X2 ----
3510 PX = INT(LX * 1.75):PY = LY * 2
3520 HPLOT PX,PY TO PX + 1,PY: HPLOT PX,PY + 1 TO PX + 1,PY + 1
3530 RETURN
5000 REM ---- THUD SOUND ----
5010 FOR Q = 1 TO 25:S = PEEK( - 16336): FOR D = 1 TO 4: NEXT D: NEXT Q
5020 RETURN
5100 REM ---- BOOM SOUND ----
5110 FOR Q = 1 TO 60:S = PEEK( - 16336): FOR D = 1 TO Q / 6: NEXT D: NEXT Q
5120 RETURN
6000 REM ====== LOCAL INPUT: ANGLE + POWER ======
6010 POKE 34,0: TEXT : HOME
6020 PRINT "YOUR TURN (";N$;")"
6030 PRINT "SCORE ";P1;" TO ";P2
6040 PRINT
6050 INPUT "ANGLE 10-80? ";A
6060 INPUT "POWER 20-100? ";P
6070 RETURN
7000 REM ====== READ ONE RELAY LINE -> RL$ ======
7005 REM LINES END IN E$=CHR$(155), THE ATASCII EOL THE ATARI SIDE SENDS
7010 IF LEN(B$) = 0 THEN 7100
7020 FOR Q = 1 TO LEN(B$): IF MID$(B$,Q,1) <> E$ THEN NEXT Q: GOTO 7100
7030 RL$ = "": IF Q > 1 THEN RL$ = LEFT$(B$,Q - 1)
7040 IF Q < LEN(B$) THEN B$ = MID$(B$,Q + 1): RETURN
7050 B$ = "": RETURN
7100 PRINT D$;"NSTATUS 1,BW,CO,ER"
7110 IF BW = 0 AND CO = 0 THEN 8900
7120 IF BW = 0 THEN 7100
7130 NB = BW: IF NB > 200 THEN NB = 200
7135 Z = 250 - LEN(B$): IF NB > Z THEN NB = Z
7137 IF NB < 1 THEN B$ = "": GOTO 7100
7140 PRINT D$;"NREAD 1,T$,NB"
7150 B$ = B$ + T$: GOTO 7010
7500 REM ---- PARSE 2 CSV VALUES FROM RL$ ----
7510 GOSUB 7560:V1 = VV: GOSUB 7560:V2 = VV: RETURN
7550 REM ---- PARSE 4 CSV VALUES FROM RL$ ----
7555 GOSUB 7560:V1 = VV: GOSUB 7560:V2 = VV: GOSUB 7560:V3 = VV: GOSUB 7560:V4 = VV: RETURN
7560 VV = VAL(RL$)
7570 FOR Q = 1 TO LEN(RL$): IF MID$(RL$,Q,1) <> "," THEN NEXT Q:RL$ = "": RETURN
7580 RL$ = MID$(RL$,Q + 1): RETURN
8000 REM ====== JOIN VIA CG GAME RELAY ======
8010 POKE 34,0: TEXT : HOME
8020 PRINT "FUJINET GORILLAS": PRINT
8030 INPUT "ENTER YOUR NAME? ";N$
8040 PRINT
8050 PRINT "FINDING AN OPPONENT..."
8060 ONERR GOTO 8890
8070 U$ = "N:TCP://RELAY.8BITATARI.COM:6502/"
8080 PRINT D$;"NOPEN 1,U$,12,0"
8100 M$ = "JOIN GORILLAS,2," + N$ + E$: GOSUB 8800
8110 GOSUB 7000
8125 IF LEN(RL$) < 4 THEN 8110
8130 IF LEFT$(RL$,4) = "WAIT" THEN PRINT "WAITING FOR PLAYER 2...": GOTO 8110
8140 IF LEN(RL$) < 11 THEN 8110
8145 IF LEFT$(RL$,4) <> "WELC" THEN 8110
8150 MT = VAL(MID$(RL$,9,1))
8160 IH = 0: IF MT = 1 THEN IH = 1
8165 PRINT "YOU ARE PLAYER ";MT
8170 REM NAME SWAP: SLOT 1 SENDS FIRST
8172 IF IH = 1 THEN M$ = N$ + E$: GOSUB 8800: GOSUB 7000:O$ = RL$
8174 IF IH = 0 THEN GOSUB 7000:O$ = RL$:M$ = N$ + E$: GOSUB 8800
8180 IF IH = 1 THEN N1$ = N$:N2$ = O$
8185 IF IH = 0 THEN N1$ = O$:N2$ = N$
8190 RETURN
8200 REM ---- HOST: SEND CITY DATA ----
8210 FOR I = 0 TO 15:M$ = STR$(H(I)) + "," + STR$(C(I)) + E$: GOSUB 8800: NEXT I
8220 M$ = STR$(GX) + "," + STR$(GY) + "," + STR$(HX) + "," + STR$(HY) + E$: GOSUB 8800
8230 RETURN
8300 REM ---- CLIENT: RECEIVE CITY DATA ----
8310 FOR I = 0 TO 15
8320 GOSUB 7000: GOSUB 7500
8330 H(I) = V1:C(I) = V2
8340 NEXT I
8350 GOSUB 7000: GOSUB 7550
8355 GX = V1:GY = V2:HX = V3:HY = V4
8360 RETURN
8400 REM ---- SEND MY SHOT ----
8410 M$ = STR$(A) + "," + STR$(P) + E$: GOSUB 8800
8420 RETURN
8500 REM ---- RECEIVE OPPONENT SHOT ----
8510 GOSUB 7000: GOSUB 7500:A = V1:P = V2
8520 RETURN
8600 REM ---- HOST: SEND PLAY-AGAIN ----
8610 M$ = A$ + E$: GOSUB 8800
8620 RETURN
8700 REM ---- CLIENT: RECEIVE PLAY-AGAIN ----
8710 GOSUB 7000:A$ = RL$
8720 RETURN
8800 REM ---- SEND LINE M$ ----
8810 ML = LEN(M$): PRINT D$;"NWRITE 1,M$,ML"
8820 RETURN
8890 EF = 1: REM ONERR ENTRY
8900 REM ====== CONNECTION LOST ======
8905 POKE 216,0: POKE 34,0: TEXT : HOME
8910 IF EF = 0 THEN PRINT "CONNECTION LOST - GAME OVER"
8915 IF EF = 1 THEN PRINT "GAME OVER - ERROR ";PEEK(222);" AT LINE ";PEEK(218) + PEEK(219) * 256
8920 PRINT D$;"NCLOSE 1": END
9000 REM ====== TITLE ======
9010 TEXT : HOME
9020 PRINT "FUJINET GORILLAS"
9030 PRINT
9040 PRINT "HGR CITY VERSION"
9050 PRINT "NETWORK PLAY VIA CG GAME RELAY"
9055 PRINT "NEEDS THE FUJIAPPLE EXTENSION LOADED"
9060 PRINT
9070 INPUT "PRESS RETURN ";A$
9090 RETURN
